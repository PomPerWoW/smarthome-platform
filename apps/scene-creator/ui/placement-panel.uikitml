<style>
  :root {
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-bg-2: rgba(255, 255, 255, 0.06);
    --glass-bg-3: rgba(255, 255, 255, 0.12);
    --glass-border: rgba(255, 255, 255, 0.16);
    --glass-border-2: rgba(255, 255, 255, 0.22);
  }

  .panel-container {
    align-items: flex-start;
    padding: 2;
    width: 45;
    height: auto;
    display: flex;
    flex-direction: column;
    background-color: var(--glass-bg);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-color: var(--glass-border);
    border-width: 0.15;
    border-radius: 2;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.18);
  }

  .panel-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1;
    margin-bottom: 1.5;
  }

  .heading {
    font-size: 2.5;
    font-weight: bold;
    color: #fafafa;
  }

  .section-label {
    font-size: 1.6;
    font-weight: bold;
    color: #a1a1aa;
    margin-top: 1.5;
    margin-bottom: 0.5;
  }

  .item-grid {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 1;
    width: 100%;
  }

  .item-btn {
    width: 19;
    padding: 1.2;
    background-color: var(--glass-bg-2);
    border-radius: 1.5;
    border-width: 0.1;
    border-color: var(--glass-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5;
    cursor: pointer;
  }

  .item-btn:hover {
    background-color: var(--glass-bg-3);
    border-color: var(--glass-border-2);
  }

  .item-icon {
    width: 4;
    height: 4;
    object-fit: contain;
  }

  .item-label {
    font-size: 1.4;
    color: #a1a1aa;
    text-align: center;
  }

  .close-btn {
    width: 100%;
    padding: 1;
    background-color: var(--glass-bg-2);
    border-color: var(--glass-border);
    border-radius: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2;
    cursor: pointer;
  }

  .close-btn:hover {
    background-color: var(--glass-bg-3);
  }

  .close-text {
    font-size: 1.6;
    color: #fafafa;
  }
</style>

<div class="panel-container">
  <div class="panel-header">
    <PackageIcon class="heading" style="width: 3; height: 3; color: #3b82f6;" />
    <span class="heading">Place Items</span>
  </div>

  <span class="section-label">Smart Devices</span>
  <div class="item-grid">
    <div class="item-btn" id="place-lightbulb">
      <img class="item-icon" src="./ui/thumbnails/lightbulb.png"></img>
      <span class="item-label">Light</span>
    </div>
    <div class="item-btn" id="place-television">
      <img class="item-icon" src="./ui/thumbnails/television.png"></img>
      <span class="item-label">TV</span>
    </div>
    <div class="item-btn" id="place-fan">
      <img class="item-icon" src="./ui/thumbnails/fan.png"></img>
      <span class="item-label">Fan</span>
    </div>
    <div class="item-btn" id="place-ac">
      <img class="item-icon" src="./ui/thumbnails/ac.png"></img>
      <span class="item-label">AC</span>
    </div>
  </div>

  <span class="section-label">Furniture</span>
  <div class="item-grid">
    <div class="item-btn" id="place-chair">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair</span>
    </div>
    <div class="item-btn" id="place-chair2">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair 2</span>
    </div>
    <div class="item-btn" id="place-chair3">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair 3</span>
    </div>
    <div class="item-btn" id="place-chair4">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair 4</span>
    </div>
    <div class="item-btn" id="place-chair5">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair 5</span>
    </div>
    <div class="item-btn" id="place-chair6">
      <img class="item-icon" src="./ui/thumbnails/chair.png"></img>
      <span class="item-label">Chair 6</span>
    </div>
  </div>

  <span class="section-label">Wallpaper</span>
  <div class="item-grid">
    <div class="item-btn" id="place-wallpaper-upload">
      <span class="item-label" style="font-size: 2.5;">🖼</span>
      <span class="item-label">Upload Image</span>
    </div>
    <div class="item-btn" id="place-wallpaper-white">
      <span class="item-label" style="font-size: 2.5; color: #f8f8f8;">■</span>
      <span class="item-label">White</span>
    </div>
    <div class="item-btn" id="place-wallpaper-cream">
      <span class="item-label" style="font-size: 2.5; color: #fdf6e3;">■</span>
      <span class="item-label">Cream</span>
    </div>
    <div class="item-btn" id="place-wallpaper-sky">
      <span class="item-label" style="font-size: 2.5; color: #bfdbfe;">■</span>
      <span class="item-label">Sky Blue</span>
    </div>
    <div class="item-btn" id="place-wallpaper-sage">
      <span class="item-label" style="font-size: 2.5; color: #bbf7d0;">■</span>
      <span class="item-label">Sage</span>
    </div>
    <div class="item-btn" id="place-wallpaper-blush">
      <span class="item-label" style="font-size: 2.5; color: #fecdd3;">■</span>
      <span class="item-label">Blush</span>
    </div>
    <div class="item-btn" id="place-wallpaper-lavender">
      <span class="item-label" style="font-size: 2.5; color: #ddd6fe;">■</span>
      <span class="item-label">Lavender</span>
    </div>
  </div>

  <div class="close-btn" id="remove-wallpaper" style="margin-top: 1; background-color: #3f1515;">
    <span class="close-text">🗑 Remove Wallpaper</span>
  </div>

  <div class="close-btn" id="close-placement">
    <span class="close-text">Close</span>
  </div>
</div>
