    <div class="dashboard-section" id="xr-section">
      <div class="section-card">
        <span class="section-title">AR / VR</span>
        <span class="section-sub">Pick a mode for the next session, then enter or exit immersive view.</span>
        <div class="xr-mode-row">
          <button class="xr-mode-btn-on" id="dash-vr-mode-btn">
            <span class="xr-mode-btn-text">VR</span>
          </button>
          <button class="xr-mode-btn-off" id="dash-ar-mode-btn">
            <span class="xr-mode-btn-text">AR</span>
          </button>
        </div>
        <button class="xr-primary-btn" id="dash-xr-primary-btn">
          <GlassesIcon class="rail-icon" />
          <span class="xr-primary-btn-text" id="dash-xr-primary-text">Enter VR</span>
        </button>
        <span class="section-sub">Body tracking (leg IK)</span>
        <div class="xr-mode-row">
          <button class="xr-mode-btn-on" id="dash-body-slimevr-btn" title="SlimeVR WebSocket bridge">
            <span class="xr-mode-btn-text">SlimeVR</span>
          </button>
          <button class="xr-mode-btn-off" id="dash-body-off-btn" title="Animated legs only, no WebSocket">
            <span class="xr-mode-btn-text">Off</span>
          </button>
        </div>
      </div>
    </div>

    <div class="dashboard-section" id="placement-section">
      <div class="section-card">
        <span class="section-title">Place Items</span>
        <span class="section-sub">Choose what to place in room.</span>
        <div class="section-grid">
          <button class="section-btn" id="place-lightbulb"><img class="section-btn-icon" src="./ui/thumbnails/lightbulb.png"></img><span class="section-btn-text">Light</span></button>
          <button class="section-btn" id="place-television"><img class="section-btn-icon" src="./ui/thumbnails/television.png"></img><span class="section-btn-text">TV</span></button>
          <button class="section-btn" id="place-fan"><img class="section-btn-icon" src="./ui/thumbnails/fan.png"></img><span class="section-btn-text">Fan</span></button>
          <button class="section-btn" id="place-ac"><img class="section-btn-icon" src="./ui/thumbnails/ac.png"></img><span class="section-btn-text">AC</span></button>
          <button class="section-btn" id="place-chair"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair</span></button>
          <button class="section-btn" id="place-chair2"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair 2</span></button>
          <button class="section-btn" id="place-chair3"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair 3</span></button>
          <button class="section-btn" id="place-chair4"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair 4</span></button>
          <button class="section-btn" id="place-chair5"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair 5</span></button>
          <button class="section-btn" id="place-chair6"><img class="section-btn-icon" src="./ui/thumbnails/chair.png"></img><span class="section-btn-text">Chair 6</span></button>
        </div>
      </div>
    </div>

    <div class="dashboard-section" id="wallpaper-section">
      <div class="section-card">
        <span class="section-title">Wallpaper</span>
        <span class="section-sub">Upload an image or pick a colour for the room walls.</span>
        <div class="section-grid">
          <button class="section-btn" id="place-wallpaper-upload"><ImageIcon class="section-btn-icon" /><span class="section-btn-text">Upload</span></button>
          <button class="section-btn" id="place-wallpaper-white"><div class="section-btn-swatch" style="background-color: #f8f8f8;"></div><span class="section-btn-text">White</span></button>
          <button class="section-btn" id="place-wallpaper-cream"><div class="section-btn-swatch" style="background-color: #fdf6e3;"></div><span class="section-btn-text">Cream</span></button>
          <button class="section-btn" id="place-wallpaper-sky"><div class="section-btn-swatch" style="background-color: #bfdbfe;"></div><span class="section-btn-text">Sky</span></button>
          <button class="section-btn" id="place-wallpaper-sage"><div class="section-btn-swatch" style="background-color: #bbf7d0;"></div><span class="section-btn-text">Sage</span></button>
          <button class="section-btn" id="place-wallpaper-blush"><div class="section-btn-swatch" style="background-color: #fecdd3;"></div><span class="section-btn-text">Blush</span></button>
          <button class="section-btn" id="place-wallpaper-lavender"><div class="section-btn-swatch" style="background-color: #ddd6fe;"></div><span class="section-btn-text">Lavender</span></button>
          <button class="section-btn" id="remove-wallpaper"><Trash2Icon class="section-btn-icon" /><span class="section-btn-text">Remove</span></button>
        </div>
      </div>
    </div>

    <div class="dashboard-section" id="alignment-section">
      <div class="section-card">
        <span class="section-title">Room Alignment</span>
        <span class="section-sub" id="alignment-status">P: (0, 0, 0) R: 0deg</span>
        <div class="section-grid">
          <button class="section-btn" id="btn-move-fwd"><span class="section-btn-text">Forward</span></button>
          <button class="section-btn" id="btn-move-back"><span class="section-btn-text">Back</span></button>
          <button class="section-btn" id="btn-move-left"><span class="section-btn-text">Left</span></button>
          <button class="section-btn" id="btn-move-right"><span class="section-btn-text">Right</span></button>
          <button class="section-btn" id="btn-move-up"><span class="section-btn-text">Up</span></button>
          <button class="section-btn" id="btn-move-down"><span class="section-btn-text">Down</span></button>
          <button class="section-btn" id="btn-rot-left"><span class="section-btn-text">Rotate CCW</span></button>
          <button class="section-btn" id="btn-rot-right"><span class="section-btn-text">Rotate CW</span></button>
        </div>
      </div>
    </div>

    <!-- ─── Voice Assistant Section (open via mic rail button) ─── -->
    <div class="dashboard-section" id="voice-section">
      <div class="voice-section-inner">
        <span class="voice-section-title">Voice Assistant</span>
        <div class="voice-orb-wrap">
          <div class="voice-orb-ring">
            <button class="voice-orb-btn" id="voice-command-btn" title="Tap to speak">
              <MicIcon class="voice-orb-icon" />
            </button>
          </div>
          <span class="voice-tip-text">Tap the mic to speak</span>
        </div>
        <div class="voice-status-badge">
          <div class="voice-status-dot" id="voice-status-dot"></div>
          <span class="voice-status-label" id="voice-status-inline">Idle</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ─── Bottom Room Tabs Bar ───────────────── -->
  <div class="room-tabs-bar" id="room-tabs">
    <div class="room-tabs-inner">
      <div class="room-tab room-tab-active" id="room-tab-0">
        <span class="room-tab-text room-tab-text-active" id="current-room-text">Current Room</span>
      </div>
      <span class="room-guide-text" id="room-guide-text">- T: toggle follow | U: toggle panel | Y: summon panel</span>
    </div>
  </div>

</div>
