# dev / dev:network inject Turing backend; use dev:backend-local for a local API, or set VITE_BACKEND_URL here.
VITE_BACKEND_URL=https://localhost:5500
# LAN IP of the machine where you run scene-creator (`dev:network`). Enter 3D World always uses https://VITE_HOST_IP:3003 when set — from local dashboard or from the frontend built for Turing. Use `npm run set-ip <ip>` to sync .env.network files.
# VITE_HOST_IP=192.168.1.10
# Rare full URL override:
# VITE_HOST_SCENE_CREATOR_URL=https://192.168.1.10:3003/smarthome/xr/
